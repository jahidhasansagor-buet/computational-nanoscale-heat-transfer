 &CONTROL
       calculation = 'bands'
      restart_mode = 'from_scratch'
        pseudo_dir = './'
            outdir = './out'
            prefix = 'gr_300K'
 /
 &SYSTEM
             ibrav = 4
                 a = 2.456 !lattice constant at 300K
                 c = 20
               nat = 2
              ntyp = 1
              nbnd = 20
       occupations = 'smearing'
          smearing = 'gaussian'
           degauss = 0.0019
           ecutwfc = 150
           assume_isolated = '2D'
 /
 &ELECTRONS
       mixing_beta = 0.7
       conv_thr    = 1.0D-8
 /
ATOMIC_SPECIES
C 12.0107 C.pbe-hgh.UPF
ATOMIC_POSITIONS (crystal)
C  0.333333333  0.666666666  0.000000000
C  0.666666666  0.333333333  0.000000000
K_POINTS (crystal_b)
4
gG 40
K  20
M  30
gG 0
